# ─── Homebrew ───────────────────────────────────────────────
if [[ -f /opt/homebrew/bin/brew ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
elif [[ -f /usr/local/bin/brew ]]; then
  eval "$(/usr/local/bin/brew shellenv)"
fi

# ─── Environment ───────────────────────────────────────────
export XDG_CONFIG_HOME="$HOME/.config"
export EDITOR='nvim'
export VISUAL='nvim'

# ─── Oh My Zsh ─────────────────────────────────────────────
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="robbyrussell"
plugins=(sudo command-not-found git colored-man-pages z docker docker-compose fnm node)

[[ -d "$ZSH" ]] && source "$ZSH/oh-my-zsh.sh"

# ─── fnm (Node version manager) ───────────────────────────
if command -v fnm &>/dev/null; then
  eval "$(fnm env --use-on-cd)"
fi

# ─── bun ───────────────────────────────────────────────────
if [[ -d "$HOME/.bun" ]]; then
  export BUN_INSTALL="$HOME/.bun"
  export PATH="$BUN_INSTALL/bin:$PATH"
  [[ -s "$HOME/.bun/_bun" ]] && source "$HOME/.bun/_bun"
fi

# ─── Ruby (keg-only, brew version over system) ────────────
if [[ -n "${HOMEBREW_PREFIX:-}" && -d "${HOMEBREW_PREFIX}/opt/ruby/bin" ]]; then
  export PATH="${HOMEBREW_PREFIX}/opt/ruby/bin:$PATH"
fi

# ─── libpq (keg-only, for Postgres projects) ──────────────
if [[ -n "${HOMEBREW_PREFIX:-}" && -d "${HOMEBREW_PREFIX}/opt/libpq" ]]; then
  export PATH="${HOMEBREW_PREFIX}/opt/libpq/bin:$PATH"
  export LDFLAGS="-L${HOMEBREW_PREFIX}/opt/libpq/lib"
  export CPPFLAGS="-I${HOMEBREW_PREFIX}/opt/libpq/include"
  export PKG_CONFIG_PATH="${HOMEBREW_PREFIX}/opt/libpq/lib/pkgconfig"
fi

# ─── PATH ──────────────────────────────────────────────────
[[ -d "$HOME/.local/bin" ]] && export PATH="$HOME/.local/bin:$PATH"

# ─── Aliases ───────────────────────────────────────────────
n() { if [ "$#" -eq 0 ]; then command nvim .; else command nvim "$@"; fi; }
alias c="clear"
alias cl="claude"
alias "cl-yolo"="claude --dangerously-skip-permissions"
alias tmux-help='echo "
  ── PANE MODE ── Ctrl+a → p → ...
     d  split down          r  split right
     x  close pane          z  zoom/unzoom
     !  pane → own window   Space  cycle layout
     h/j/k/l  navigate      Tab  next pane

  ── TAB MODE ── Ctrl+a → t → ...
     n  new tab             x  close tab
     ,  rename              Tab  last tab
     h/l  prev/next         1-9  jump to tab

  ── RESIZE MODE ── Ctrl+a → R → ... (sticky, Esc to exit)
     h/j/k/l  resize (2px)
     H/J/K/L  resize (5px)

  ── MOVE MODE ── Ctrl+a → m → ... (sticky, Esc to exit)
     h/j/k/l  swap pane

  ── DIRECT (Ctrl+a → touche) ──
     |  split right     -  split down     c  new window
     s  sessions        w  windows        z  zoom
     d  detach          r  reload         [  copy mode
     1-9  jump to tab

  ── SANS PREFIX ──
     Ctrl+h/j/k/l  navigate panes

  ── COPY MODE (Ctrl+a → [) ──
     v  select    y  copy to clipboard    q  quit
     /  search    n/N  next/prev match
     drag souris = copie auto
"'

# ─── Optional sources ─────────────────────────────────────
[[ -f "$HOME/.local/bin/env" ]] && . "$HOME/.local/bin/env"

# ─── Machine-specific config ──────────────────────────────
# Add local overrides to ~/.zshrc.local, not here.
[[ -f "$HOME/.zshrc.local" ]] && source "$HOME/.zshrc.local"
